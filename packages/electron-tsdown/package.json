{
  "name": "electron-tsdown",
  "version": "11.0.2",
  "description": "Use tsdown and vite with Electron for blazing fast compilation",
  "keywords": [
    "cli",
    "electron",
    "hmr",
    "hot reload",
    "tsdown",
    "vite"
  ],
  "license": "MIT",
  "author": "Kiyozz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiyozz/electron-tsdown.git",
    "directory": "packages/electron-tsdown"
  },
  "bin": {
    "electron-tsdown": "./dist/run.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsdown",
    "prepublishOnly": "tsc -b && tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check.",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@adonisjs/fold": "^11.0.0",
    "cac": "^7.0.0",
    "debounce-fn": "^6.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tinyexec": "^1.1.1",
    "unconfig": "^7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsdown": "^0.21.9",
    "typescript": "~6.0.2",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "tsdown": "^0.21.7",
    "vite": "8.x"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "10"
  }
}
