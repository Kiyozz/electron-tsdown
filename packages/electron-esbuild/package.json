{
  "name": "electron-esbuild",
  "version": "10.0.0",
  "keywords": [
    "esbuild",
    "electron",
    "renderer",
    "hmr",
    "hot reload",
    "cli"
  ],
  "type": "module",
  "description": "Use esbuild with Electron for blazing fast compilation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiyozz/electron-esbuild.git",
    "directory": "packages/electron-esbuild"
  },
  "author": "Kiyozz",
  "license": "MIT",
  "bin": {
    "electron-esbuild": "./dist/run.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": "10"
  },
  "scripts": {
    "build": "tsc -b && tsdown",
    "prepublishOnly": "tsc -b && tsdown",
    "lint": "eslint src --ext ts,js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@sindresorhus/is": "^7.2.0",
    "debounce-fn": "^6.0.0",
    "deepmerge": "^4.3.1",
    "dependency-tree": "^11.4.0",
    "js-yaml": "^4.1.1",
    "meow": "^14.1.0",
    "unconfig": "^7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/has": "^1.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "tsdown": "^0.21.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.7"
  },
  "peerDependencies": {
    "tsdown": "^0.21.7",
    "vite": "8.x"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
