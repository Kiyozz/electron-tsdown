{
  "name": "electron-esbuild",
  "version": "10.0.0",
  "keywords": [
    "tsdown",
    "vite",
    "electron",
    "hmr",
    "hot reload",
    "cli"
  ],
  "type": "module",
  "description": "Use tsdown and vite with Electron for blazing fast compilation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiyozz/electron-esbuild.git",
    "directory": "packages/electron-esbuild"
  },
  "author": "Kiyozz",
  "license": "MIT",
  "bin": {
    "electron-tsdown": "./dist/run.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": "10"
  },
  "scripts": {
    "build": "tsc -b && tsdown",
    "prepublishOnly": "tsc -b && tsdown",
    "lint": "eslint src --ext ts,js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@adonisjs/fold": "^11.0.0",
    "cac": "^7.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "tinyexec": "^1.1.1",
    "unconfig": "^7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsdown": "^0.21.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.7"
  },
  "peerDependencies": {
    "tsdown": "^0.21.7",
    "vite": "8.x"
  }
}
