{
  "name": "@electron-tsdown/create-app",
  "version": "10.0.2",
  "description": "Create Electron tsdown powered apps with one command",
  "keywords": [
    "cli",
    "create-app",
    "electron",
    "react",
    "svelte",
    "tsdown"
  ],
  "license": "MIT",
  "author": "Kiyozz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiyozz/electron-tsdown.git",
    "directory": "packages/create-app"
  },
  "bin": {
    "create-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "exports": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsdown",
    "prepublishOnly": "tsc -b && tsdown",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "enquirer": "^2.4.1",
    "kolorist": "^1.8.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.19.17",
    "tsdown": "^0.21.9",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "10"
  }
}
