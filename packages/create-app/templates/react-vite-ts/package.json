{
  "name": "react-vite-typescript",
  "version": "1.0.0",
  "description": "A simple Electron app built with electron-tsdown",
  "author": "built by electron-tsdown",
  "type": "module",
  "scripts": {
    "dev": "electron-tsdown dev",
    "build": "electron-tsdown build",
    "package": "electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.15.20",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-tsdown": "^11.0.0",
    "electron-util": "^1.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "io.comp.myapp",
    "productName": "react-vite-typescript",
    "extraMetadata": {
      "name": "react-vite-typescript",
      "main": "main.js"
    },
    "files": [
      {
        "from": ".",
        "filter": [
          "package.json"
        ]
      },
      {
        "from": "dist/main"
      },
      {
        "from": "dist/renderer"
      }
    ],
    "win": {
      "target": [
        "zip"
      ]
    },
    "mac": {
      "target": [
        "zip"
      ]
    },
    "linux": {
      "target": [
        "zip"
      ]
    },
    "directories": {
      "buildResources": "resources"
    },
    "publish": null
  }
}
